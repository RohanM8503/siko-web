---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import AppsBar from '../components/AppsBar.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Method from '../components/Method.astro';
import ProbeSection from '../components/ProbeSection.astro';
import Features from '../components/Features.astro';
import ReportSection from '../components/ReportSection.astro';
import Dashboard from '../components/Dashboard.astro';
import Privacy from '../components/Privacy.astro';
import FAQ from '../components/FAQ.astro';
import About from '../components/About.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main id="main">
    <Hero />
    <AppsBar />
    <HowItWorks />
    <Method />
    <ProbeSection />
    <Features />
    <ReportSection />
    <Dashboard />
    <Privacy />
    <FAQ />
    <About />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
