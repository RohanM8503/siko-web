---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page not found — Siko" description="That page doesn't exist. Back to trysiko.com.">
  <Nav />
  <main id="main" class="section section-y">
    <div class="container-page">
      <div class="max-w-[44ch] mx-auto text-center pt-10 pb-24 md:pt-20 md:pb-32">
        <p class="eyebrow">404</p>
        <h1 class="mt-5 font-serif text-display-2 text-ink-900 leading-[1.05]">
          Page not found.
        </h1>
        <p class="mt-6 text-ink-600 text-[16.5px] leading-[1.65]">
          The page you&rsquo;re looking for isn&rsquo;t here. It might have moved,
          or it might never have existed.
        </p>
        <div class="mt-10">
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-full bg-ink-900 text-cream-100 px-5 py-3 text-[14px] font-medium hover:bg-ink-700 transition-colors"
          >
            Back to home
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
