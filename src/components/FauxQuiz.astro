---
// Small inline mock of Siko's Quiz Me card. Distinct blue accent
// (matches overlay.html #quiz-card border).
//
// The problem here is an SAT-flavored algebra question with the
// classic SAT trap: the equation gives you x but the question asks
// for x + 4. Demonstrates that Siko's quiz pipeline (per
// lib/prompts.js QUIZ_GENERATE_PROMPT_TEMPLATE) is "solvable in 1-3
// steps" and benefits from the lenient form grading.
---
<div class="faux-quiz">
  <div class="meta">Quiz me</div>
  <div class="prob">If 2(x &minus; 3) = 10, what is x + 4?</div>
  <input class="input" type="text" value="" placeholder="Your answer… (note: it's x + 4, not x)" disabled />
  <div class="actions">
    <button class="btn" type="button" disabled>Done</button>
    <button class="btn primary" type="button" disabled>Check</button>
  </div>
</div>

<style>
  .faux-quiz {
    width: 100%;
    max-width: 400px;
    padding: 16px 18px;
    background: rgba(22, 24, 30, 0.96);
    border: 1px solid rgba(120, 180, 255, 0.45);
    border-radius: 14px;
    color: rgba(255, 255, 255, 0.94);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter Variable', Inter, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.45), 0 0 28px 4px rgba(120, 180, 255, 0.18);
  }
  .meta {
    font-size: 10px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(120, 180, 255, 0.95);
    font-weight: 700;
    margin-bottom: 8px;
  }
  .prob {
    font-family: 'Fraunces Variable', Fraunces, serif;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.97);
    margin-bottom: 10px;
  }
  .input {
    width: 100%;
    padding: 9px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.20);
    background: rgba(0, 0, 0, 0.38);
    color: rgba(255, 255, 255, 0.85);
    font: inherit;
    font-size: 13px;
    font-style: italic;
    margin-bottom: 10px;
    box-sizing: border-box;
  }
  .input::placeholder {
    color: rgba(255, 255, 255, 0.45);
    font-style: italic;
  }
  .actions { display: flex; gap: 8px; justify-content: flex-end; }
  .btn {
    font: inherit;
    font-size: 12.5px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 7px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.92);
    cursor: not-allowed;
    opacity: 0.95;
  }
  .btn.primary {
    background: rgba(120, 180, 255, 0.22);
    border-color: rgba(120, 180, 255, 0.60);
    color: rgba(220, 235, 255, 0.98);
  }
</style>
