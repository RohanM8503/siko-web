---
// Generic file-type icons for the AppsBar pills. Deliberately abstract
// rather than brand-specific: a document is a document whether it's
// Pages or Word; a PDF is a PDF whether it's Preview or Acrobat. This
// avoids reproducing trademarked brand logos we don't have license for,
// and reads as "this kind of surface" rather than "we integrate with X."
interface Props {
  name: 'doc' | 'pdf' | 'notebook' | 'web' | 'math' | 'book';
  size?: number;
  class?: string;
}
const { name, size = 16, class: className = '' } = Astro.props;
---

{name === 'doc' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    <path d="M3 1.5h5.5L11 4v8.5H3z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round"/>
    <path d="M8.5 1.5v2.5H11" stroke="currentColor" stroke-width="0.9"/>
    <line x1="4.5" y1="7"  x2="9.5" y2="7"  stroke="currentColor" stroke-width="0.7"/>
    <line x1="4.5" y1="9"  x2="9.5" y2="9"  stroke="currentColor" stroke-width="0.7"/>
    <line x1="4.5" y1="11" x2="8"   y2="11" stroke="currentColor" stroke-width="0.7"/>
  </svg>
)}

{name === 'pdf' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    <path d="M3 1.5h5.5L11 4v8.5H3z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round"/>
    <path d="M8.5 1.5v2.5H11" stroke="currentColor" stroke-width="0.9"/>
    <text x="7" y="11" font-size="3.5" text-anchor="middle" fill="currentColor" font-weight="700" font-family="ui-monospace, monospace">PDF</text>
  </svg>
)}

{name === 'notebook' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    <rect x="3.5" y="2" width="8" height="10" stroke="currentColor" stroke-width="0.9" rx="0.5"/>
    <line x1="1.5" y1="3.5" x2="3.5" y2="3.5" stroke="currentColor" stroke-width="0.7"/>
    <line x1="1.5" y1="5.5" x2="3.5" y2="5.5" stroke="currentColor" stroke-width="0.7"/>
    <line x1="1.5" y1="7.5" x2="3.5" y2="7.5" stroke="currentColor" stroke-width="0.7"/>
    <line x1="1.5" y1="9.5" x2="3.5" y2="9.5" stroke="currentColor" stroke-width="0.7"/>
    <line x1="5.5" y1="6" x2="9.5" y2="6" stroke="currentColor" stroke-width="0.5"/>
    <line x1="5.5" y1="8" x2="9.5" y2="8" stroke="currentColor" stroke-width="0.5"/>
  </svg>
)}

{name === 'web' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    <rect x="1.5" y="2.5" width="11" height="9" stroke="currentColor" stroke-width="0.9" rx="0.5"/>
    <line x1="1.5" y1="5" x2="12.5" y2="5" stroke="currentColor" stroke-width="0.9"/>
    <circle cx="3"   cy="3.75" r="0.5" fill="currentColor"/>
    <circle cx="4.5" cy="3.75" r="0.5" fill="currentColor"/>
    <circle cx="6"   cy="3.75" r="0.5" fill="currentColor"/>
  </svg>
)}

{name === 'math' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    {/* tiny graph: axes + curve — reads as "graphing calculator" */}
    <line x1="2" y1="12" x2="12" y2="12" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
    <line x1="2" y1="12" x2="2"  y2="2"  stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
    <path d="M3 11 Q 6 4, 11 3" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round"/>
  </svg>
)}

{name === 'book' && (
  <svg width={size} height={size} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true">
    <path d="M2 4 L2 11 L7 10 L12 11 L12 4 L7 5 Z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round" fill="none"/>
    <line x1="7" y1="5" x2="7" y2="10" stroke="currentColor" stroke-width="0.9"/>
  </svg>
)}
