---
import SikoMark from './SikoMark.astro';
---

<header class="sticky top-0 z-30 backdrop-blur-md bg-cream/80 border-b border-ink-100/60">
  <div class="container-page section flex h-14 items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-2 text-ink-900 hover:text-gold-400 transition-colors"
      aria-label="Siko home"
    >
      <SikoMark size={24} tone="#B8893A" />
      <span class="font-serif text-[18px] tracking-tight" style="font-variation-settings: 'opsz' 14, 'SOFT' 50;">
        siko
      </span>
    </a>
    <nav class="hidden md:flex items-center gap-7 font-mono text-[12px] text-ink-600">
      <a href="#how" class="hover:text-ink-900 transition-colors">How it works</a>
      <a href="#method" class="hover:text-ink-900 transition-colors">Method</a>
      <a href="#patterns" class="hover:text-ink-900 transition-colors">Patterns</a>
      <a href="#privacy" class="hover:text-ink-900 transition-colors">Privacy</a>
      <a href="#faq" class="hover:text-ink-900 transition-colors">FAQ</a>
    </nav>
    <a
      href="#waitlist"
      class="font-mono text-[12px] inline-flex items-center gap-1.5 rounded-full bg-ink-900 text-cream px-3.5 py-1.5 hover:bg-ink-700 transition-colors"
    >
      Join waitlist
      <span aria-hidden="true" class="text-cream-300">↗</span>
    </a>
  </div>
</header>
