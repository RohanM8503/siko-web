---
// Final CTA — the waitlist. POSTs to api.trysiko.com, which is a
// Cloudflare Worker that validates the email, adds it to the Resend
// "Waitlist" audience, and sends a confirmation. JS intercepts the
// submit so the user stays on this page; the form still works without
// JS (the response will be a plain JSON body in that case).
---

<section id="waitlist" class="section section-y bg-ink-900 text-cream-100 relative overflow-hidden">
  {/* Faint gold accent in the corner — a single, calm flourish. */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-32 -right-32 w-[440px] h-[440px] rounded-full"
    style="background: radial-gradient(closest-side, rgba(255, 216, 77, 0.16), transparent 70%);"
  ></div>

  <div class="container-page relative">
    <div class="max-w-[640px] mx-auto text-center">
      <p class="font-mono text-[11px] uppercase tracking-eyebrow text-gold-200">
        Onboarding one student at a time
      </p>
      <h2 class="mt-5 font-serif text-display-2">
        Get on the waitlist.
      </h2>
      <p class="mt-6 text-ink-200 text-[16.5px] leading-[1.6] max-w-[52ch] mx-auto">
        You&rsquo;ll hear from us when your spot opens up &mdash; not before.
        Charter members get their first month free. After that, Siko is
        <strong class="text-cream font-medium">$20/month</strong>, flat.
        No drip, no newsletter.
      </p>

      <form
        action="https://api.trysiko.com"
        method="POST"
        class="mt-10 flex flex-col sm:flex-row gap-3 max-w-[480px] mx-auto"
        id="waitlist-form"
      >
        <label class="sr-only" for="waitlist-email">Email address</label>
        <input
          id="waitlist-email"
          type="email"
          name="email"
          required
          placeholder="you@yourinbox.com"
          class="flex-1 rounded-full px-5 py-3 bg-white/10 border border-white/20 placeholder:text-ink-400 text-cream focus:outline-none focus:ring-2 focus:ring-gold-300 focus:border-transparent"
          autocomplete="email"
        />
        <button
          type="submit"
          class="rounded-full px-6 py-3 bg-gold-300 text-ink-900 font-medium hover:bg-gold-200 transition-colors"
        >
          Join
        </button>
        {/* Honeypot — invisible to humans, fillable by naive bots.
            The Worker silently succeeds (does nothing) when this is set. */}
        <div
          aria-hidden="true"
          style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"
        >
          <label for="waitlist-company">Company (leave this blank)</label>
          <input
            id="waitlist-company"
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
          />
        </div>
      </form>
      <p id="waitlist-disclaimer" class="mt-4 font-mono text-[11px] text-ink-300">
        We&rsquo;ll never share your email. Unsubscribe any time &mdash; one link in every email.
      </p>
      <p
        id="waitlist-error"
        hidden
        role="alert"
        class="mt-4 font-mono text-[11px] text-rose-200"
      ></p>

      <div
        id="waitlist-thanks"
        hidden
        class="mt-10 p-5 rounded-2xl border border-gold-200/30 bg-white/5"
      >
        <p class="font-serif text-[18px] text-cream">Thanks &mdash; you&rsquo;re on the list.</p>
        <p class="mt-2 text-ink-200 text-[14px]">
          We&rsquo;ll be in touch. In the meantime, you might enjoy the
          <a href="#about" class="underline decoration-gold-300 underline-offset-4 hover:text-cream">founder note</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('waitlist-form');
    var thanks = document.getElementById('waitlist-thanks');
    var errorEl = document.getElementById('waitlist-error');
    var disclaimer = document.getElementById('waitlist-disclaimer');
    if (!form || !thanks) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var button = form.querySelector('button[type="submit"]');
      var originalLabel = button ? button.textContent : '';
      if (button) {
        button.disabled = true;
        button.textContent = 'Joining…';
      }
      if (errorEl) errorEl.hidden = true;

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      })
        .then(function (res) {
          return res.json().catch(function () { return {}; });
        })
        .then(function (data) {
          if (data && data.ok) {
            form.style.display = 'none';
            if (disclaimer) disclaimer.style.display = 'none';
            thanks.hidden = false;
          } else {
            if (button) { button.disabled = false; button.textContent = originalLabel; }
            if (errorEl) {
              errorEl.textContent =
                data && data.error === 'invalid_email'
                  ? 'Hmm — that email doesn’t look right. Try again?'
                  : 'Something went sideways. Try again in a moment?';
              errorEl.hidden = false;
            }
          }
        })
        .catch(function () {
          if (button) { button.disabled = false; button.textContent = originalLabel; }
          if (errorEl) {
            errorEl.textContent = 'Network hiccup — try again in a moment?';
            errorEl.hidden = false;
          }
        });
    });
  })();
</script>
