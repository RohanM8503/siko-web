---
// Small placeholder logo mark — a four-pointed star sparkle, alluding to
// the Siko → magic + scholar-astrologers etymology without being kitschy.
// User will replace with their own logo later.
interface Props {
  size?: number;
  class?: string;
  /** stroke / fill color; defaults to currentColor so the mark inherits
   *  whatever the parent text color is. */
  tone?: string;
}
const { size = 22, class: className = '', tone = 'currentColor' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  class={className}
  aria-hidden="true"
>
  {/* Vertical diamond */}
  <path
    d="M12 1.5 L13.6 10.4 L12 12 L10.4 10.4 Z"
    fill={tone}
    opacity="0.96"
  />
  <path
    d="M12 22.5 L13.6 13.6 L12 12 L10.4 13.6 Z"
    fill={tone}
    opacity="0.96"
  />
  {/* Horizontal diamond */}
  <path
    d="M22.5 12 L13.6 13.6 L12 12 L13.6 10.4 Z"
    fill={tone}
    opacity="0.96"
  />
  <path
    d="M1.5 12 L10.4 13.6 L12 12 L10.4 10.4 Z"
    fill={tone}
    opacity="0.96"
  />
</svg>
